# Whisper-PTT (Apple Silicon) — example config. Copy to .env and set your values.
# Uses mlx-whisper (Metal). Requires Apple Silicon Mac.

# Whisper model (MLX HuggingFace repo or short name: large-v3, large-v3-turbo, tiny, base, small, medium)
WHISPER_PTT_WHISPER_MODEL=large-v3-turbo
# Whisper language: en, ru, de, fr or other code
WHISPER_PTT_WHISPER_LANGUAGE=en
WHISPER_PTT_WHISPER_INITIAL_PROMPT=English speech.

# Hotkey (default: option)
WHISPER_PTT_HOTKEY=option

# LLM cleanup (true/false) — optional, OFF by default
WHISPER_PTT_USE_LLM_CLEANUP=false
WHISPER_PTT_OLLAMA_MODEL=qwen2.5:14b
WHISPER_PTT_OLLAMA_URL=http://localhost:11434/api/generate
# LLM cleanup prompt: optional. Use {detected_lang} and {raw_text}. Omit for built-in default.
# WHISPER_PTT_LLM_CLEANUP_PROMPT="Fix the transcription. Language: {detected_lang}. Return only cleaned text.\n\n{raw_text}"

# Copy to clipboard (true/false)
WHISPER_PTT_COPY_TO_CLIPBOARD=true
# Paste to active window (true/false)
WHISPER_PTT_PASTE_TO_ACTIVE_WINDOW=true
# Clipboard after paste (only when Paste is on): restore | clear | preserve
# restore = put back what was in clipboard before; clear = empty clipboard; preserve = leave transcription
WHISPER_PTT_CLIPBOARD_AFTER_PASTE_POLICY=restore
# Keys after paste: key(s) to send (enter, ctrl+enter, or empty/none)
WHISPER_PTT_KEYS_AFTER_PASTE=enter

# Audio: sample rate, chunk size
WHISPER_PTT_SAMPLE_RATE=16000
WHISPER_PTT_CHUNK_SIZE=1024

# Prebuffer (sec), padding (sec), min frames, silence gate
WHISPER_PTT_PREBUFFER_SEC=0.5
WHISPER_PTT_PADDING_SEC=0.2
WHISPER_PTT_MIN_FRAMES=5
WHISPER_PTT_SILENCE_AMPLITUDE=750
